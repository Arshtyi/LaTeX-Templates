% --- Caption Formatting ---
\usepackage[format=hang,font=small,textfont=it]{caption} % Advanced caption control

% --- Enhanced Graphics Utility Command ---
\define@key{incfig}{scale}{\def\figscale{#1}}
\define@key{incfig}{float}{\def\figfloat{#1}}
\define@key{incfig}{caption}{\def\figcaption{#1}}
\define@key{incfig}{label}{\def\figlabel{#1}}

\newcommand{\incfig}[2][]{%
    % #1: Optional parameters (scale, float, caption, label)
    % #2: Figure name (required)
    \def\svgwidth{\columnwidth}%
    \def\figcaption{}%
    \def\figlabel{}%
    \def\figscale{}%
    \def\figfloat{htbp}%

    % Parse options using keyval package
    \setkeys{incfig}{#1}%

    % Apply scaling if specified
    \ifthenelse{\equal{\figscale}{}}{%
        % No scaling specified, use columnwidth
        \def\svgwidth{\columnwidth}%
    }{%
        % Use specified scaling
        \def\svgwidth{\figscale\columnwidth}%
    }%

    \ifthenelse{\equal{\figcaption}{}}{%
        % No caption - just include the figure
        \import{./Figures/}{#2.pdf_tex}
    }{%
        % Caption provided - use figure environment
        \expandafter\figure\expandafter[\figfloat]
        \centering
        \import{./Figures/}{#2.pdf_tex}
        \caption{\figcaption}
        \ifthenelse{\equal{\figlabel}{}}{}{%
            \label{\figlabel}%
        }
        \endfigure
    }
}% <- Comment to prevent parsing errors

% --- Figure and Subfigure Configuration ---
\renewcommand{\figurename}{Figure} % Default figure caption prefix
\DeclareCaptionFormat{subfig}{Figure \thefigure~-~(#1): #3} % Custom subfigure caption format
\captionsetup[subfigure]{format=subfig, labelformat=simple} % Apply subfigure format
\renewcommand{\thesubfigure}{\alph{subfigure}} % Use lowercase letters for subfigures

% --- Subfigure Reference Format ---
\makeatletter
\renewcommand{\p@subfigure}{\thefigure~-~(} % Prefix for subfigure references
\renewcommand{\thesubfigure}{\alph{subfigure})} % Suffix for subfigure references
\makeatother

% --- Cross-reference Names for Figures ---
\crefname{figure}{Figure}{Figures} % Names for figure references (singular, plural)
\crefname{subfigure}{Figure}{Figures} % Names for subfigure references (singular, plural)

