% --- Bibliography Generation Command ---
\newcommand{\generateBibliography}[1]{%
    \newpage%                   % Start on a new page
    \pagenumbering{Roman}%      % Use Roman numerals for page numbers
    \setcounter{page}{1}%       % Reset page counter to 1
    \pagestyle{plain}%          % Use plain page style
    \nocite{*}%                 % Include all entries from bibliography
    \bibliographystyle{plain}%  % Use plain bibliography style
    \clearpage%                 % Start a new page
    \phantomsection%            % For correct hyperlinks
    \renewcommand{\bibname}{References}% % Rename bibliography section
    \addcontentsline{toc}{chapter}{References}% % Add to table of contents
    \bibliography{#1}%          % Generate bibliography from specified file
}% <- Comment to prevent parsing errors

