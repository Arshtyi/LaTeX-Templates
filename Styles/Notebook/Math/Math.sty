% --- Bibliography Generation Command ---
\newcommand{\generateBibliography}[1]{%
    \newpage%
    \pagenumbering{Roman}%
    \setcounter{page}{1}%
    \pagestyle{plain}%
    \nocite{*}%
    \bibliographystyle{plain}%
    \clearpage%
    \phantomsection%
    \renewcommand{\bibname}{References}%
    \addcontentsline{toc}{chapter}{References}%
    \bibliography{#1}%
}

